generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model UserAccount {
  id           String        @id @default(cuid())
  email        String        @unique
  displayName  String?
  passwordHash String
  passwordSalt String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  jobs     JobPosting[]
  momentumCheckIns MomentumCheckIn[]
  momentumEvidence MomentumEvidence[]
  momentumGoals MomentumGoal[]
  momentumIntegrations MomentumIntegration[]
  momentumTasks MomentumTask[]
  profiles UserProfile[]
  savedSearches SavedSearch[]
  sessions UserSession[]
}

model UserSession {
  id            String      @id @default(cuid())
  userAccountId String
  tokenHash     String      @unique
  expiresAt     DateTime
  createdAt     DateTime    @default(now())

  userAccount UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id                  String    @id @default(cuid())
  userAccountId       String?   @unique
  legalName           String
  preferredName       String?
  email               String
  phone               String?
  location            String?
  school              String?
  degree              String?
  major               String?
  minor               String?
  graduationDate      DateTime?
  gpa                 String?
  workAuthorization   String?
  careerInterests     String?
  sponsorshipRequired Boolean   @default(false)
  earliestStartDate   DateTime?
  preferredTerms      String    @default("[]")
  preferredLocations  String    @default("[]")
  remotePreference    String?
  portfolioUrl        String?
  githubUrl           String?
  linkedinUrl         String?
  websiteUrl          String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  applications Application[]
  facts        ProfileFact[]
  files        FileAsset[]
  resumes      Resume[]
  userAccount  UserAccount? @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
}

model ProfileFact {
  id                 String    @id @default(cuid())
  userProfileId      String
  type               String
  title              String
  organization       String?
  location           String?
  startDate          DateTime?
  endDate            DateTime?
  description        String
  impact             String?
  skills             String    @default("[]")
  evidenceNote       String?
  resumeAllowed      Boolean   @default(true)
  coverLetterAllowed Boolean   @default(true)
  answersAllowed     Boolean   @default(true)
  verified           Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  userProfile UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
}

model Resume {
  id             String          @id @default(cuid())
  userProfileId  String
  name           String
  baseType       String
  rawText        String
  structuredJson String?
  isMaster       Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  userProfile UserProfile     @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  versions    ResumeVersion[]
}

model ResumeVersion {
  id                  String       @id @default(cuid())
  resumeId            String
  jobPostingId        String?
  applicationId       String?
  name                String
  tailoredText        String
  structuredJson      String?
  htmlPreview         String?
  pdfPath             String?
  docxPath            String?
  truthCheckJson      String?
  keywordCoverageJson String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  jobPosting  JobPosting?  @relation(fields: [jobPostingId], references: [id], onDelete: SetNull)
  resume      Resume       @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model Company {
  id        String       @id @default(cuid())
  name      String
  website   String?
  domain    String?
  industry  String?
  size      String?
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  jobs JobPosting[]
}

model JobPosting {
  id                      String          @id @default(cuid())
  userAccountId           String?
  companyId               String
  title                   String
  location                String?
  workplaceType           String?
  internshipTerm          String?
  sourceUrl               String?
  sourceName              String?
  atsProvider             String?
  rawDescription          String
  parsedJson              String?
  requiredQualifications  String          @default("[]")
  preferredQualifications String          @default("[]")
  responsibilities        String          @default("[]")
  technologies            String          @default("[]")
  keywords                String          @default("[]")
  compensation            String?
  deadline                DateTime?
  riskFlagsJson           String          @default("[]")
  dedupeHash              String
  importedAt              DateTime        @default(now())
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  applications   Application[]
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  questions      JobQuestion[]
  resumeVersions ResumeVersion[]
  userAccount    UserAccount?    @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
}

model JobQuestion {
  id            String              @id @default(cuid())
  jobPostingId  String
  questionText  String
  questionType  String              @default("text")
  required      Boolean             @default(false)
  optionsJson   String?
  sensitive     Boolean             @default(false)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  answers    ApplicationAnswer[]
  jobPosting JobPosting         @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
}

model JobSource {
  id           String      @id @default(cuid())
  provider     String      @unique
  label        String
  enabled      Boolean     @default(true)
  lastSyncedAt DateTime?
  configJson   String      @default("{}")
  lastError    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  sourcedJobs SourcedJob[]

  @@index([enabled, provider])
}

model SourcedJob {
  id                       String    @id @default(cuid())
  sourceId                 String
  provider                 String
  externalId               String
  company                  String
  title                    String
  location                 String?
  workplaceType            String?
  internshipTerm           String?
  sourceUrl                String?
  rawDescription           String
  parsedJson               String?
  requiredQualifications   String    @default("[]")
  preferredQualifications  String    @default("[]")
  responsibilities         String    @default("[]")
  technologies             String    @default("[]")
  keywords                 String    @default("[]")
  compensationMin          Int?
  compensationMax          Int?
  compensationText         String?
  visaSponsorshipFriendly  Boolean   @default(false)
  workAuthNotRequired      Boolean   @default(false)
  deadline                 DateTime?
  postedAt                 DateTime?
  expiresAt                DateTime?
  riskFlagsJson            String    @default("[]")
  fetchedAt                DateTime  @default(now())
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  source JobSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, externalId])
  @@index([provider])
  @@index([company])
  @@index([title])
  @@index([postedAt])
  @@index([deadline])
}

model SavedSearch {
  id            String    @id @default(cuid())
  userAccountId String
  name          String
  queryJson     String
  alertCadence  String    @default("none")
  lastRunAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userAccount UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)

  @@index([userAccountId])
  @@index([alertCadence])
}

model Application {
  id              String    @id @default(cuid())
  userProfileId   String
  jobPostingId    String
  status          String    @default("drafted")
  applicationMode String    @default("manual")
  fitScore        Int       @default(0)
  fitAnalysisJson String?
  approvedAt      DateTime?
  submittedAt     DateTime?
  source          String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  answers            ApplicationAnswer[]
  coverLetters       CoverLetter[]
  files              FileAsset[]
  followUps          FollowUpTask[]
  jobPosting         JobPosting          @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  resumeVersions     ResumeVersion[]
  submissionAttempts SubmissionAttempt[]
  userProfile        UserProfile         @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
}

model ApplicationAnswer {
  id                   String       @id @default(cuid())
  applicationId         String
  jobQuestionId         String?
  answerText            String
  supportingFactIdsJson String       @default("[]")
  truthCheckStatus      String       @default("needs_user_input")
  userApproved          Boolean      @default(false)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  jobQuestion JobQuestion? @relation(fields: [jobQuestionId], references: [id], onDelete: SetNull)
}

model CoverLetter {
  id                   String      @id @default(cuid())
  applicationId         String
  text                 String
  supportingFactIdsJson String      @default("[]")
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model FileAsset {
  id            String   @id @default(cuid())
  userProfileId String?
  applicationId String?
  type          String
  filename      String
  path          String
  mimeType      String?
  size          Int?
  createdAt     DateTime @default(now())

  application Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userProfile UserProfile? @relation(fields: [userProfileId], references: [id], onDelete: SetNull)
}

model SubmissionAttempt {
  id                  String      @id @default(cuid())
  applicationId        String
  adapter              String
  status               String
  requestSummaryJson   String?
  responseSummaryJson  String?
  errorMessage         String?
  createdAt            DateTime    @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           String   @id @default(cuid())
  entityType   String
  entityId     String
  action       String
  metadataJson String?
  createdAt    DateTime @default(now())
}

model FollowUpTask {
  id            String      @id @default(cuid())
  applicationId String
  title         String
  dueDate       DateTime?
  completed     Boolean     @default(false)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model MomentumGoal {
  id             String    @id @default(cuid())
  userAccountId  String
  title          String
  category       String    @default("school")
  why            String?
  successMetric  String?
  targetDate     DateTime?
  cadence        String    @default("weekly")
  status         String    @default("active")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tasks       MomentumTask[]
  userAccount UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)

  @@index([userAccountId, status])
  @@index([targetDate])
}

model MomentumTask {
  id               String    @id @default(cuid())
  userAccountId    String
  goalId           String?
  source           String    @default("manual")
  externalId       String?
  title            String
  description      String?
  category         String    @default("school")
  priority         String    @default("medium")
  estimatedMinutes Int       @default(45)
  dueAt            DateTime?
  status           String    @default("todo")
  proofRequired    Boolean   @default(true)
  proofNote        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  completedAt      DateTime?

  evidence    MomentumEvidence[]
  goal        MomentumGoal? @relation(fields: [goalId], references: [id], onDelete: SetNull)
  userAccount UserAccount   @relation(fields: [userAccountId], references: [id], onDelete: Cascade)

  @@index([userAccountId, status])
  @@index([dueAt])
  @@index([source, externalId])
}

model MomentumEvidence {
  id            String   @id @default(cuid())
  userAccountId String
  taskId        String?
  source        String   @default("manual")
  title         String
  url           String?
  summary       String
  skillsJson    String   @default("[]")
  capturedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  task        MomentumTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  userAccount UserAccount   @relation(fields: [userAccountId], references: [id], onDelete: Cascade)

  @@index([userAccountId])
  @@index([source])
}

model MomentumIntegration {
  id            String    @id @default(cuid())
  userAccountId String
  provider      String
  label         String
  status        String    @default("not_connected")
  configJson    String    @default("{}")
  lastSyncedAt  DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userAccount UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)

  @@unique([userAccountId, provider])
  @@index([userAccountId, status])
}

model MomentumCheckIn {
  id               String   @id @default(cuid())
  userAccountId    String
  mood             String?
  availableMinutes Int      @default(120)
  focus            String?
  blockers         String?
  planJson         String   @default("[]")
  createdAt        DateTime @default(now())

  userAccount UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)

  @@index([userAccountId, createdAt])
}

model AppSettings {
  id                        String   @id @default("singleton")
  llmProvider               String   @default("mock")
  aiModel                   String?
  aiInstructions            String?
  defaultResumeTemplate     String   @default("software_engineering")
  targetRoleTypes           String   @default("[]")
  targetIndustries          String   @default("[]")
  excludedKeywords          String   @default("[]")
  disableSubmissionAdapters Boolean  @default(false)
  requireReview             Boolean  @default(true)
  maxApplicationsPerDay     Int      @default(10)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}
