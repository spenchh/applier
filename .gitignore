/node_modules
/.pnp
.pnp.js

# Next.js
/.next/
/out/
next-env.d.ts

# Production
/build

# Local database (SQLite) — never commit the dev database
/prisma/*.db
/prisma/*.db-journal
/prisma/dev.db
*.sqlite
*.sqlite3

# Generated Prisma client
/src/generated
/node_modules/.prisma

# Local file storage — uploaded resumes and generated documents must never be committed
/storage/
!/storage/.gitkeep

# Environment variables / secrets
.env
.env*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Testing
/coverage

# OS / editor
.DS_Store
*.pem
.idea/
.vscode/
*.tsbuildinfo

# Misc generated documents
*.tmp
