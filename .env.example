# ---------------------------------------------------------------------------
# InternPilot environment configuration
# Copy this file to ".env" and fill in values. NEVER commit your real .env.
# ---------------------------------------------------------------------------

# Database connection string.
# Local development uses SQLite (default below).
# For production, point this at a Postgres-compatible database and switch the
# datasource provider in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# ---------------------------------------------------------------------------
# LLM provider configuration
# LLM_PROVIDER selects which backend the tailoring/analysis features use.
#   "mock"      -> deterministic local responses, NO API key required (default)
#   "anthropic" -> requires ANTHROPIC_API_KEY
#   "openai"    -> requires OPENAI_API_KEY
# The app runs fully without any paid API by leaving this as "mock".
# ---------------------------------------------------------------------------
LLM_PROVIDER="mock"

# Optional — only needed when LLM_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
# Optional model override
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Optional — only needed when LLM_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ---------------------------------------------------------------------------
# Encryption
# 32-byte key (base64 or hex) used to encrypt sensitive profile fields at rest.
# Generate one with:  openssl rand -base64 32
# If unset in development, a non-persistent dev key is derived (NOT for prod).
# ---------------------------------------------------------------------------
ENCRYPTION_KEY=""

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_BASE_URL="http://localhost:3000"

# Optional — only used if/when authentication is enabled (not in MVP).
NEXTAUTH_SECRET=""

# ---------------------------------------------------------------------------
# Email (Email Mode) — all optional.
# If not configured, Email Mode exports a draft (.eml) instead of sending.
# ---------------------------------------------------------------------------
EMAIL_FROM=""
RESEND_API_KEY=""

# Optional Gmail OAuth (future: draft creation). Not used for sending in MVP.
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
